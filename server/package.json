{
  "name": "@ledgermind/server",
  "version": "0.1.0",
  "private": true,
  "description": "LedgerMind backend — Express + Mongoose, class-based hexagonal architecture.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "start:worker": "tsx src/worker/index.ts",
    "seed": "tsx src/scripts/seed.ts",
    "migrate:models": "tsx src/scripts/migrateModels.ts",
    "reevaluate:risk": "tsx src/scripts/reevaluateRisk.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "mongoose": "^8.5.1",
    "zod": "^3.23.8",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.11",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "license": "MIT"
}
