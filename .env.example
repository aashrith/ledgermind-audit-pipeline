# ─── LedgerMind Audit Pipeline — environment template ───
# Copy to server/.env and adjust as needed.

# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/ledgermind

# Intelligence / model versioning
MODEL_VERSION=v1
RISK_VERSION=v1

# Worker tuning
WORKER_POLL_INTERVAL_MS=1000
WORKER_ENRICH_DELAY_MS=400
WORKER_MAX_ATTEMPTS=3
WORKER_ID=worker-local

# Migration / reevaluation batch sizing
BATCH_SIZE=100
