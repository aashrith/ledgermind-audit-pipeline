# ─── LedgerMind Audit Pipeline — environment template ───
# Copy to server/.env and adjust as needed.

# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/ledgermind

# Intelligence / model versioning
MODEL_VERSION=v1
RISK_VERSION=v1

# Worker tuning
WORKER_POLL_INTERVAL_MS=1000
WORKER_ENRICH_DELAY_MS=400
WORKER_MAX_ATTEMPTS=3
WORKER_ID=worker-local

# Migration / reevaluation batch sizing
BATCH_SIZE=100

# ─── Predictability / bounded-work controls ───
# MongoDB connection pool (bounds DB concurrency; fail fast on selection)
MONGO_MAX_POOL_SIZE=20
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Ingress protection (fail fast, don't degrade)
RATE_LIMIT_WINDOW_MS=10000
RATE_LIMIT_MAX=300
REQUEST_TIMEOUT_MS=15000

# Admission control on the ENRICHMENT path (never the ledger write).
# Above this backlog, new entries persist but defer enqueue to the sweeper.
MAX_QUEUE_DEPTH=5000
QUEUE_DEPTH_TTL_MS=1000

# Sweeper drains deferred/orphaned entries; reaper reclaims stuck jobs.
SWEEPER_INTERVAL_MS=5000
SWEEPER_BATCH=100
JOB_LOCK_TTL_MS=60000

# Bounded similarity fan-out (candidates compared per query)
SIMILARITY_CANDIDATE_LIMIT=1000
